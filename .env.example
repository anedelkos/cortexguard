# CortexGuard Edge — Environment Variables
# Copy to .env and adjust as needed. All variables are optional with the defaults shown.
# See docs/OPERATIONS.md for full descriptions.

# --- Identity ---
DEVICE_ID=mock_01
RUNTIME_PROFILE=default

# --- LLM Policy Engine ---
POLICY_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
POLICY_USE_MOCK=true
POLICY_REMEDIATION_COOLDOWN_S=30.0

# --- LLM Circuit Breaker ---
LLM_TIMEOUT_S=30.0
LLM_FAILURE_THRESHOLD=3
LLM_COOLDOWN_S=60.0

# --- Ingestion ---
INGEST_RATE_LIMIT=100/second

# --- Persistence ---
PERSISTENCE_ENABLED=false
PERSISTENCE_FILE_PATH=/var/lib/cortexguard/blackboard.json
PERSISTENCE_SNAPSHOT_INTERVAL=5.0

# --- Observability ---
OTLP_ENDPOINT=http://tempo:4318/v1/traces
LOG_LEVEL=INFO
LOG_JSON=true

# --- Safety ---
SAFETY_RADIUS_M=0.5

# --- Detection Thresholds ---
DETECTOR_TEMP_THRESHOLD_C=70.0
DETECTOR_Z_SCORE_THRESHOLD=5.0
ESTIMATOR_SIGMA_THRESHOLD=3.0

# --- Fusion ---
FUSION_FORCE_MIN_N=0.0
FUSION_FORCE_DROP_PCT=100.1
FUSION_DRIFT_FAIL_MM=10.0
FUSION_SMOKE_PPM_THRESHOLD=50.0
FUSION_EXPECTED_PERIOD_MS=50
FUSION_SOFT_DEGRADE_MS=200
FUSION_MAX_GAP_MS=500
