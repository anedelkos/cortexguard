{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Pytest",
            "type": "python",
            "request": "launch",
            "program": "/opt/venvs/cortexguard/bin/pytest",
            "args": [
                "-s",
                "tests"
            ],
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        }
    ]
}


